 int global_verbose_level;
 const char *global_tool_name;
 
+#ifdef PYSTUDIO_FORK_TRACE
+static FILE *pystudio_trace_log;
+static bool pystudio_trace_log_checked;
+
+static FILE *get_pystudio_trace_log(void)
+{
+	const char *path;
+	const char *prefix;
+	char generated_path[PATH_MAX];
+	char dir_path[PATH_MAX];
+	time_t now;
+
+	if (pystudio_trace_log_checked)
+		return pystudio_trace_log;
+	pystudio_trace_log_checked = true;
+
+	path = getenv("PYSTUDIO_PROOT_TRACE_LOG");
+	if (path == NULL || path[0] == '\0') {
+		prefix = getenv("PREFIX");
+		if (prefix == NULL || prefix[0] == '\0')
+			return NULL;
+		snprintf(dir_path, sizeof(dir_path), "%s/var", prefix);
+		(void) mkdir(dir_path, 0700);
+		snprintf(dir_path, sizeof(dir_path), "%s/var/log", prefix);
+		(void) mkdir(dir_path, 0700);
+		snprintf(dir_path, sizeof(dir_path), "%s/var/log/pystudio", prefix);
+		(void) mkdir(dir_path, 0700);
+		snprintf(generated_path, sizeof(generated_path),
+				"%s/proot-fork-trace.log", dir_path);
+		path = generated_path;
+	}
+
+	pystudio_trace_log = fopen(path, "a");
+	if (pystudio_trace_log == NULL)
+		return NULL;
+
+	now = time(NULL);
+	fprintf(pystudio_trace_log,
+		"\n[pystudio-proot-trace] pid=%ld time=%ld tool=%s\n",
+		(long) getpid(), (long) now, global_tool_name ?: "");
+	fflush(pystudio_trace_log);
+	return pystudio_trace_log;
+}
+#endif
+
