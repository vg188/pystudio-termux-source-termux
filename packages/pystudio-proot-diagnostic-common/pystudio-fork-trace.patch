@@ -73,6 +128,9 @@ void note(const Tracee *tracee, Severity severity, Origin origin, const char *me
 		fprintf(stderr, "talloc: ");
 
 	va_start(extra_params, message);
+#ifdef PYSTUDIO_FORK_TRACE
+	va_copy(trace_params, extra_params);
+#endif
 	vfprintf(stderr, message, extra_params);
 	va_end(extra_params);
 
@@ -92,6 +150,28 @@ void note(const Tracee *tracee, Severity severity, Origin origin, const char *me
 		break;
 	}
 
+#ifdef PYSTUDIO_FORK_TRACE
+	trace_log = get_pystudio_trace_log();
+	if (trace_log != NULL) {
+		fprintf(trace_log, "%s %s: ",
+			tool_name,
+			severity == ERROR ? "error" : severity == WARNING ? "warning" : "info");
+		if (origin == TALLOC)
+			fprintf(trace_log, "talloc: ");
+		vfprintf(trace_log, message, trace_params);
+		switch (origin) {
+		case SYSTEM:
+			fprintf(trace_log, ": %s\n", strerror(errno));
+			break;
+		default:
+			fprintf(trace_log, "\n");
+			break;
+		}
+		fflush(trace_log);
+	}
+	va_end(trace_params);
+#endif
+
 	return;
 }
 
