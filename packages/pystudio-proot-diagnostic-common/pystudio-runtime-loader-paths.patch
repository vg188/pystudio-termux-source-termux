 }
 #endif
 
+#if defined(PROOT_UNBUNDLE_LOADER)
+static char *format_unbundled_loader_path(const char *prefix, bool wants_32bit_version)
+{
+	const char *name = wants_32bit_version ? "loader32" : "loader";
+
+	return talloc_asprintf(talloc_autofree_context(),
+			"%s/libexec/proot/%s", prefix, name);
+}
+
+static char *derive_prefix_from_executable(void)
+{
+	char path[PATH_MAX];
+	char *slash;
+	ssize_t length;
+
+	length = readlink("/proc/self/exe", path, sizeof(path) - 1);
+	if (length <= 0)
+		return NULL;
+
+	path[length] = '\0';
+
+	/* Expected installation path: $PREFIX/bin/proot. */
+	slash = strrchr(path, '/');
+	if (slash == NULL)
+		return NULL;
+	*slash = '\0';
+
+	slash = strrchr(path, '/');
+	if (slash == NULL)
+		return NULL;
+	*slash = '\0';
+
+	return talloc_strdup(talloc_autofree_context(), path);
+}
+
+static const char *resolve_unbundled_loader_path(const Tracee *tracee,
+		bool wants_32bit_version)
+{
+#if defined(HAS_LOADER_32BIT)
+	static char *loader32_path = NULL;
+#endif
+	static char *loader_path = NULL;
+	const char *env_name;
+	const char *env_path;
+	const char *prefix;
+	char **cache;
+
+#if defined(HAS_LOADER_32BIT)
+	if (wants_32bit_version) {
+		env_name = "PROOT_LOADER_32";
+		cache = &loader32_path;
+	}
+	else
+#endif
+	{
+		env_name = "PROOT_LOADER";
+		cache = &loader_path;
+	}
+
+	if (*cache != NULL)
+		return *cache;
+
+	env_path = getenv(env_name);
+	if (env_path != NULL && env_path[0] != '\0') {
+		*cache = (char *) env_path;
+		return *cache;
+	}
+
+	prefix = getenv("PREFIX");
+	if (prefix != NULL && prefix[0] != '\0')
+		*cache = format_unbundled_loader_path(prefix, wants_32bit_version);
+
+	if (*cache == NULL) {
+		char *derived_prefix = derive_prefix_from_executable();
+
+		if (derived_prefix != NULL)
+			*cache = format_unbundled_loader_path(derived_prefix,
+					wants_32bit_version);
+	}
+
+	if (*cache != NULL && tracee->verbose >= 2)
+		note(tracee, INFO, INTERNAL, "loader: %s", *cache);
+
+	return *cache;
+}
+#endif
+
 /**
  * Get the path to the loader for the given @tracee.  This function
